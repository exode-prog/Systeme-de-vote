import { useState, useEffect } from 'react';
import { getCandidats, validerCandidat, rejeterCandidat } from '../../services/api';

export default function GererCandidats() {
  const [candidats, setCandidats] = useState([]);
  const [loading, setLoading]     = useState(true);
  const [message, setMessage]     = useState(null);
  const [filtre, setFiltre]       = useState('tous');

  useEffect(() => { fetchData(); }, []);

  const fetchData = async () => {
    try {
      const res = await getCandidats();
      setCandidats(res.data);
    } catch (err) {
      console.error(err);
    } finally {
      setLoading(false);
    }
  };

  const handleValider = async (id) => {
    if (!window.confirm('Valider cette candidature ?')) return;
    try {
      await validerCandidat(id);
      setMessage({ type: 'success', text: '✅ Candidature validée !' });
      fetchData();
    } catch (err) {
      setMessage({ type: 'error', text: err.response?.data?.message || 'Erreur' });
    }
    setTimeout(() => setMessage(null), 4000);
  };

  const handleRejeter = async (id) => {
    if (!window.confirm('Rejeter cette candidature ?')) return;
    try {
      await rejeterCandidat(id);
      setMessage({ type: 'success', text: '✅ Candidature rejetée' });
      fetchData();
    } catch (err) {
      setMessage({ type: 'error', text: err.response?.data?.message || 'Erreur' });
    }
    setTimeout(() => setMessage(null), 4000);
  };

  const statutConfig = {
    en_attente: { label: 'En attente', bg: '#fff8e1', color: '#f57c00', dot: '#fbbc04' },
    valide:     { label: 'Validé',     bg: '#e6f4ea', color: '#2e7d32', dot: '#34a853' },
    rejete:     { label: 'Rejeté',     bg: '#fce8e6', color: '#c62828', dot: '#ea4335' },
  };

  const filtres = filtre === 'tous'
    ? candidats
    : candidats.filter(c => c.statut === filtre);

  if (loading) return (
    <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', height: '300px' }}>
      <div style={{ width: '40px', height: '40px', border: '3px solid #e8f0fe', borderTopColor: '#1a73e8', borderRadius: '50%', animation: 'spin 0.8s linear infinite' }} />
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
    </div>
  );

  return (
    <div>
      <div style={{ marginBottom: '28px' }}>
        <h1 style={{ fontSize: '24px', fontWeight: 800, color: '#202124', marginBottom: '6px' }}>
          👥 Gestion des candidatures
        </h1>
        <p style={{ fontSize: '14px', color: '#9aa0a6' }}>
          Validez ou rejetez les candidatures des étudiants
        </p>
      </div>

      {message && (
        <div style={{
          background: message.type === 'success' ? '#e6f4ea' : '#fce8e6',
          borderLeft: `4px solid ${message.type === 'success' ? '#34a853' : '#ea4335'}`,
          color: message.type === 'success' ? '#2e7d32' : '#c62828',
          padding: '12px 16px', borderRadius: '8px', fontSize: '14px', marginBottom: '20px',
        }}>
          {message.text}
        </div>
      )}

      <div style={{ display: 'flex', gap: '8px', marginBottom: '20px', flexWrap: 'wrap' }}>
        {[
          { id: 'tous',       label: `Tous (${candidats.length})` },
          { id: 'en_attente', label: `En attente (${candidats.filter(c => c.statut === 'en_attente').length})` },
          { id: 'valide',     label: `Validés (${candidats.filter(c => c.statut === 'valide').length})` },
          { id: 'rejete',     label: `Rejetés (${candidats.filter(c => c.statut === 'rejete').length})` },
        ].map(f => (
          <button
            key={f.id}
            onClick={() => setFiltre(f.id)}
            style={{
              padding: '8px 16px', borderRadius: '8px', border: 'none',
              fontSize: '13px', fontWeight: 600, cursor: 'pointer',
              transition: 'all 0.2s ease',
              background: filtre === f.id ? '#1a73e8' : '#f8f9fa',
              color: filtre === f.id ? 'white' : '#5f6368',
            }}
            onMouseEnter={(e) => { if (filtre !== f.id) e.currentTarget.style.background = '#e8f0fe'; }}
            onMouseLeave={(e) => { if (filtre !== f.id) e.currentTarget.style.background = '#f8f9fa'; }}
          >
            {f.label}
          </button>
        ))}
      </div>

      {filtres.length === 0 ? (
        <div style={{ background: 'white', borderRadius: '16px', padding: '60px', textAlign: 'center', color: '#9aa0a6', boxShadow: '0 1px 4px rgba(0,0,0,0.06)' }}>
          <div style={{ fontSize: '48px', marginBottom: '12px' }}>👥</div>
          <div style={{ fontSize: '16px', fontWeight: 600, color: '#202124', marginBottom: '6px' }}>Aucune candidature</div>
          <div style={{ fontSize: '13px' }}>Les candidatures apparaîtront ici</div>
        </div>
      ) : (
        <div style={{ display: 'flex', flexDirection: 'column', gap: '14px' }}>
          {filtres.map((candidat) => {
            const s = statutConfig[candidat.statut] || statutConfig.en_attente;
            return (
              <div key={candidat.id_candidat} style={{
                background: 'white', borderRadius: '14px', padding: '22px',
                boxShadow: '0 1px 4px rgba(0,0,0,0.06)',
                borderLeft: `4px solid ${s.dot}`,
                transition: 'all 0.2s ease',
              }}
                onMouseEnter={(e) => { e.currentTarget.style.boxShadow = '0 8px 20px rgba(0,0,0,0.08)'; }}
                onMouseLeave={(e) => { e.currentTarget.style.boxShadow = '0 1px 4px rgba(0,0,0,0.06)'; }}
              >
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', flexWrap: 'wrap', gap: '12px' }}>
                  <div style={{ display: 'flex', alignItems: 'center', gap: '14px' }}>
                    <div style={{
                      width: '48px', height: '48px', background: '#e8f0fe',
                      borderRadius: '14px', display: 'flex', alignItems: 'center',
                      justifyContent: 'center', fontSize: '20px', fontWeight: 800, color: '#1a73e8',
                    }}>
                      {candidat.nom?.charAt(0).toUpperCase()}
                    </div>
                    <div>
                      <div style={{ fontSize: '15px', fontWeight: 700, color: '#202124', marginBottom: '2px' }}>
                        {candidat.prenom} {candidat.nom}
                      </div>
                      <div style={{ fontSize: '12px', color: '#9aa0a6', marginBottom: '2px' }}>{candidat.email}</div>
                      <div style={{ fontSize: '12px', color: '#1a73e8', fontWeight: 600 }}>
                        📚 {candidat.classe}
                      </div>
                    </div>
                  </div>
                  <div style={{ display: 'flex', alignItems: 'center', gap: '8px', flexWrap: 'wrap' }}>
                    <span style={{
                      background: s.bg, color: s.color,
                      padding: '4px 12px', borderRadius: '20px',
                      fontSize: '11px', fontWeight: 600,
                      display: 'flex', alignItems: 'center', gap: '4px',
                    }}>
                      <span style={{ width: '6px', height: '6px', background: s.dot, borderRadius: '50%', display: 'inline-block' }} />
                      {s.label}
                    </span>
                    {candidat.statut === 'en_attente' && (
                      <>
                        <button
                          onClick={() => handleValider(candidat.id_candidat)}
                          style={{
                            background: '#e6f4ea', color: '#2e7d32', border: 'none',
                            padding: '8px 16px', borderRadius: '8px',
                            fontSize: '13px', fontWeight: 600, cursor: 'pointer',
                            transition: 'all 0.2s ease',
                          }}
                          onMouseEnter={(e) => { e.currentTarget.style.background = '#34a853'; e.currentTarget.style.color = 'white'; }}
                          onMouseLeave={(e) => { e.currentTarget.style.background = '#e6f4ea'; e.currentTarget.style.color = '#2e7d32'; }}
                        >
                          ✅ Valider
                        </button>
                        <button
                          onClick={() => handleRejeter(candidat.id_candidat)}
                          style={{
                            background: '#fce8e6', color: '#c62828', border: 'none',
                            padding: '8px 16px', borderRadius: '8px',
                            fontSize: '13px', fontWeight: 600, cursor: 'pointer',
                            transition: 'all 0.2s ease',
                          }}
                          onMouseEnter={(e) => { e.currentTarget.style.background = '#ea4335'; e.currentTarget.style.color = 'white'; }}
                          onMouseLeave={(e) => { e.currentTarget.style.background = '#fce8e6'; e.currentTarget.style.color = '#c62828'; }}
                        >
                          ❌ Rejeter
                        </button>
                      </>
                    )}
                  </div>
                </div>
                <div style={{
                  background: '#f8f9fa', borderRadius: '10px', padding: '12px 14px',
                  marginTop: '14px', fontSize: '13px', color: '#5f6368',
                  lineHeight: 1.6, borderLeft: '3px solid #1a73e8',
                }}>
                  {candidat.programme}
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}
