import { useState } from 'react';
import Header from '../../components/Header';
import Footer from '../../components/Footer';
import Dashboard from './Dashboard';
import Elections from './Elections';
import Candidature from './Candidature';
import Vote from './Vote';
import Commentaires from './Commentaires';

const menuItems = [
  { id: 'dashboard',    label: 'Accueil',        icon: '🏠' },
  { id: 'elections',    label: 'Elections',       icon: '🗳️' },
  { id: 'candidature',  label: 'Ma candidature',  icon: '👤' },
  { id: 'vote',         label: 'Voter',           icon: '✅' },
  { id: 'commentaires', label: 'Commentaires',    icon: '💬' },
];

export default function EtudiantLayout() {
  const [currentPage, setCurrentPage] = useState('dashboard');

  const renderPage = () => {
    switch (currentPage) {
      case 'dashboard':    return <Dashboard setCurrentPage={setCurrentPage} />;
      case 'elections':    return <Elections setCurrentPage={setCurrentPage} />;
      case 'candidature':  return <Candidature />;
      case 'vote':         return <Vote />;
      case 'commentaires': return <Commentaires />;
      default:             return <Dashboard setCurrentPage={setCurrentPage} />;
    }
  };

  return (
    <div style={{
      minHeight: '100vh', display: 'flex', flexDirection: 'column',
      background: '#f5f7fa', fontFamily: "'Inter', 'Segoe UI', sans-serif",
    }}>
      <Header
        menuItems={menuItems}
        currentPage={currentPage}
        setCurrentPage={setCurrentPage}
      />
      <main style={{ flex: 1, paddingTop: '80px', paddingBottom: '32px' }}>
        <div style={{ maxWidth: '1280px', margin: '0 auto', padding: '32px 24px' }}>
          {renderPage()}
        </div>
      </main>
      <Footer />
    </div>
  );
}
