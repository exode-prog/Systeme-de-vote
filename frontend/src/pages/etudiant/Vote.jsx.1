import { useState, useEffect } from 'react';
import { getElections, getCandidats, getResultats, voter } from '../../services/api';
import { io } from 'socket.io-client';

const socket = io('http://192.168.138.42:3000');

export default function Vote() {
  const [elections, setElections]   = useState([]);
  const [election, setElection]     = useState(null);
  const [candidats, setCandidats]   = useState([]);
  const [resultats, setResultats]   = useState([]);
  const [loading, setLoading]       = useState(true);
  const [voteEnCours, setVoteEnCours] = useState(false);
  const [message, setMessage]       = useState(null);

  useEffect(() => {
    fetchElections();
  }, []);

  useEffect(() => {
    if (election) {
      socket.emit('rejoindreElection', election.id_election);
      socket.on('resultatsMAJ', (data) => setResultats(data));
      fetchDetails(election.id_election);
    }
    return () => socket.off('resultatsMAJ');
  }, [election]);

  const fetchElections = async () => {
    try {
      const res = await getElections();
      const ouvertes = res.data.filter(e => e.statut === 'ouverte');
      setElections(ouvertes);
      if (ouvertes.length === 1) setElection(ouvertes[0]);
    } catch (err) {
      console.error(err);
    } finally {
      setLoading(false);
    }
  };

  const fetchDetails = async (id) => {
    try {
      const [c, r] = await Promise.all([getCandidats(), getResultats(id)]);
      setCandidats(c.data);
      setResultats(r.data.resultats);
    } catch (err) {
      console.error(err);
    }
  };

  const handleVoter = async (id_candidat) => {
    if (!election) return;
    setVoteEnCours(true);
    try {
      await voter({ id_candidat, id_election: election.id_election });
      setMessage({ type: 'success', text: '✅ Votre vote a été soumis avec succès !' });
      fetchDetails(election.id_election);
    } catch (err) {
      setMessage({ type: 'error', text: err.response?.data?.message || 'Erreur lors du vote' });
    } finally {
      setVoteEnCours(false);
      setTimeout(() => setMessage(null), 5000);
    }
  };

  const totalVotes = resultats.reduce((sum, r) => sum + parseInt(r.nombre_votes || 0), 0);

  if (loading) return (
    <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', height: '300px' }}>
      <div style={{
        width: '40px', height: '40px',
        border: '3px solid #e8f0fe', borderTopColor: '#1a73e8',
        borderRadius: '50%', animation: 'spin 0.8s linear infinite',
      }} />
      <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
    </div>
  );

  if (elections.length === 0) return (
    <div>
      <h1 style={{ fontSize: '24px', fontWeight: 800, color: '#202124', marginBottom: '6px' }}>
        ✅ Voter
      </h1>
      <div style={{
        background: 'white', borderRadius: '16px', padding: '60px',
        textAlign: 'center', color: '#9aa0a6', marginTop: '24px',
        boxShadow: '0 1px 4px rgba(0,0,0,0.06)',
      }}>
        <div style={{ fontSize: '56px', marginBottom: '16px' }}>🔒</div>
        <div style={{ fontSize: '18px', fontWeight: 700, marginBottom: '8px', color: '#202124' }}>
          Aucune élection ouverte
        </div>
        <div style={{ fontSize: '14px' }}>
          Le vote n'est pas disponible pour le moment
        </div>
      </div>
    </div>
  );

  return (
    <div>
      <div style={{ marginBottom: '28px' }}>
        <h1 style={{ fontSize: '24px', fontWeight: 800, color: '#202124', marginBottom: '6px' }}>
          ✅ Voter
        </h1>
        <p style={{ fontSize: '14px', color: '#9aa0a6' }}>
          Choisissez votre candidat — votre vote est définitif
        </p>
      </div>

      {elections.length > 1 && (
        <div style={{ marginBottom: '20px' }}>
          <select
            value={election?.id_election || ''}
            onChange={(e) => {
              const el = elections.find(el => el.id_election === parseInt(e.target.value));
              setElection(el);
            }}
            style={{
              padding: '11px 14px', border: '1.5px solid #e0e0e0',
              borderRadius: '8px', fontSize: '14px', outline: 'none',
              background: 'white', cursor: 'pointer',
            }}
          >
            <option value="">Choisir une élection</option>
            {elections.map(el => (
              <option key={el.id_election} value={el.id_election}>{el.nom}</option>
            ))}
          </select>
        </div>
      )}

      {message && (
        <div style={{
          background: message.type === 'success' ? '#e6f4ea' : '#fce8e6',
          borderLeft: `4px solid ${message.type === 'success' ? '#34a853' : '#ea4335'}`,
          color: message.type === 'success' ? '#2e7d32' : '#c62828',
          padding: '14px 16px', borderRadius: '8px',
          fontSize: '14px', marginBottom: '20px',
        }}>
          {message.text}
        </div>
      )}

      {election && (
        <div style={{ display: 'grid', gridTemplateColumns: '1fr 320px', gap: '24px' }}>
          <div>
            <h2 style={{ fontSize: '17px', fontWeight: 700, color: '#202124', marginBottom: '16px' }}>
              Choisissez votre candidat
            </h2>
            <div style={{ display: 'flex', flexDirection: 'column', gap: '14px' }}>
              {candidats.map((candidat) => (
                <div key={candidat.id_candidat} style={{
                  background: 'white', borderRadius: '14px', padding: '22px',
                  boxShadow: '0 1px 4px rgba(0,0,0,0.06)',
                  transition: 'all 0.2s ease',
                }}
                  onMouseEnter={(e) => {
                    e.currentTarget.style.boxShadow = '0 8px 24px rgba(0,0,0,0.1)';
                    e.currentTarget.style.transform = 'translateY(-2px)';
                  }}
                  onMouseLeave={(e) => {
                    e.currentTarget.style.boxShadow = '0 1px 4px rgba(0,0,0,0.06)';
                    e.currentTarget.style.transform = 'translateY(0)';
                  }}
                >
                  <div style={{ display: 'flex', alignItems: 'center', gap: '14px', marginBottom: '14px' }}>
                    <div style={{
                      width: '50px', height: '50px', background: '#e8f0fe',
                      borderRadius: '14px', display: 'flex', alignItems: 'center',
                      justifyContent: 'center', fontSize: '22px', fontWeight: 800, color: '#1a73e8',
                    }}>
                      {candidat.nom?.charAt(0).toUpperCase()}
                    </div>
                    <div>
                      <div style={{ fontSize: '16px', fontWeight: 700, color: '#202124' }}>
                        {candidat.prenom} {candidat.nom}
                      </div>
                      <div style={{ fontSize: '12px', color: '#9aa0a6' }}>{candidat.classe}</div>
                    </div>
                  </div>
                  <div style={{
                    background: '#f8f9fa', borderRadius: '10px', padding: '14px',
                    fontSize: '13px', color: '#5f6368', lineHeight: 1.7,
                    borderLeft: '3px solid #1a73e8', marginBottom: '16px',
                  }}>
                    {candidat.programme}
                  </div>
                  <button
                    onClick={() => handleVoter(candidat.id_candidat)}
                    disabled={voteEnCours}
                    style={{
                      width: '100%', padding: '12px',
                      background: '#1a73e8', color: 'white',
                      border: 'none', borderRadius: '8px',
                      fontSize: '14px', fontWeight: 700,
                      cursor: voteEnCours ? 'not-allowed' : 'pointer',
                      transition: 'all 0.2s ease',
                      opacity: voteEnCours ? 0.6 : 1,
                      boxShadow: '0 4px 12px rgba(26,115,232,0.3)',
                    }}
                    onMouseEnter={(e) => { if (!voteEnCours) { e.currentTarget.style.background = '#0d47a1'; e.currentTarget.style.transform = 'translateY(-1px)'; } }}
                    onMouseLeave={(e) => { if (!voteEnCours) { e.currentTarget.style.background = '#1a73e8'; e.currentTarget.style.transform = 'translateY(0)'; } }}
                  >
                    {voteEnCours ? '⏳ Vote en cours...' : '✅ Voter pour ce candidat'}
                  </button>
                </div>
              ))}
            </div>
          </div>

          <div style={{ position: 'sticky', top: '80px' }}>
            <div style={{
              background: 'white', borderRadius: '14px', padding: '22px',
              boxShadow: '0 1px 4px rgba(0,0,0,0.06)',
            }}>
              <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '16px' }}>
                <span style={{
                  width: '8px', height: '8px', background: '#34a853',
                  borderRadius: '50%', display: 'inline-block',
                  animation: 'pulse 1.5s infinite',
                }} />
                <h3 style={{ fontSize: '15px', fontWeight: 700, color: '#202124' }}>
                  Résultats en direct
                </h3>
              </div>
              {resultats.length === 0 ? (
                <div style={{ textAlign: 'center', color: '#9aa0a6', padding: '20px 0', fontSize: '13px' }}>
                  Aucun vote pour le moment
                </div>
              ) : (
                <div style={{ display: 'flex', flexDirection: 'column', gap: '14px' }}>
                  {resultats.map((r, i) => {
                    const pct = totalVotes > 0 ? Math.round((parseInt(r.nombre_votes) / totalVotes) * 100) : 0;
                    return (
                      <div key={r.id_candidat}>
                        <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '6px' }}>
                          <span style={{ fontSize: '13px', fontWeight: 600, color: '#202124' }}>
                            {i === 0 ? '🥇' : i === 1 ? '🥈' : '🥉'} {r.prenom} {r.nom}
                          </span>
                          <span style={{ fontSize: '13px', fontWeight: 700, color: '#1a73e8' }}>
                            {pct}%
                          </span>
                        </div>
                        <div style={{ background: '#f0f0f0', borderRadius: '6px', height: '8px', overflow: 'hidden' }}>
                          <div style={{
                            height: '100%', borderRadius: '6px',
                            background: i === 0 ? 'linear-gradient(90deg, #1a73e8, #4285f4)' : '#bdc1c6',
                            width: `${pct}%`, transition: 'width 0.6s ease',
                          }} />
                        </div>
                        <div style={{ fontSize: '11px', color: '#9aa0a6', marginTop: '3px' }}>
                          {r.nombre_votes} vote(s)
                        </div>
                      </div>
                    );
                  })}
                  <div style={{
                    borderTop: '1px solid #f0f0f0', paddingTop: '12px',
                    display: 'flex', justifyContent: 'space-between',
                  }}>
                    <span style={{ fontSize: '13px', color: '#9aa0a6' }}>Total</span>
                    <span style={{ fontSize: '14px', fontWeight: 800, color: '#202124' }}>{totalVotes} votes</span>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      )}

      <style>{`
        @keyframes spin { to { transform: rotate(360deg); } }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
      `}</style>
    </div>
  );
}
